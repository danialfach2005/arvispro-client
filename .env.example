# --- ARVISPRO CLIENT ENV CONFIG ---
# Gunakan file ini sebagai template untuk membuat file .env.local untuk development
# Untuk production (Vercel), masukkan nilai ini di tab Settings > Environment Variables

# Base URL API
# Contoh: https://api.arvispro.com/graphql
VITE_GRAPHQL_ENDPOINT=https://api.arvispro.com/graphql

# Tambahkan variabel lain di bawah ini dengan prefix VITE_
# VITE_ANALYTICS_ID=UA-XXXXX-Y
